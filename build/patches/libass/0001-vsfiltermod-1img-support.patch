diff --git a/libass/ass.h b/libass/ass.h
index b7b1663..3a57244 100644
--- a/libass/ass.h
+++ b/libass/ass.h
@@ -79,6 +79,14 @@ typedef struct ass_image {
         IMAGE_TYPE_SHADOW
     } type;
 
+    // VSFilterMod \1img/\2img/\3img/\4img 纹理路径
+    // channel_images[0] = primary fill (\1img)
+    // channel_images[1] = secondary fill (\2img)
+    // channel_images[2] = outline/border (\3img)
+    // channel_images[3] = shadow (\4img)
+    // 为 NULL 表示该通道不使用纹理
+    const char *channel_images[4];
+
     // New fields can be added here in new ABI-compatible library releases.
 } ASS_Image;
 
