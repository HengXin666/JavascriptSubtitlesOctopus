diff --git a/libass/ass_parse.c b/libass/ass_parse.c
index fae575a..db1aaa5 100644
--- a/libass/ass_parse.c
+++ b/libass/ass_parse.c
@@ -450,8 +450,16 @@ char *ass_parse_tags(RenderContext *state, char *p, char *end, double pwr,
                 val = state->style->ScaleY;
             state->scale_y = val;
         } else if (tag("fsc")) {
-            state->scale_x = state->style->ScaleX;
-            state->scale_y = state->style->ScaleY;
+            // VSFilterMod: \fsc<number> 等比缩放, \fsc 无参数则重置
+            if (nargs) {
+                double val = argtod(*args) / 100;
+                val = (val < 0) ? 0 : val;
+                state->scale_x = state->scale_x * (1 - pwr) + val * pwr;
+                state->scale_y = state->scale_y * (1 - pwr) + val * pwr;
+            } else {
+                state->scale_x = state->style->ScaleX;
+                state->scale_y = state->style->ScaleY;
+            }
         } else if (tag("fsp")) {
             double val;
             if (nargs) {
@@ -912,6 +920,205 @@ char *ass_parse_tags(RenderContext *state, char *p, char *end, double pwr,
             else
                 val = state->style->Encoding;
             state->font_encoding = val;
+
+        // =====================================================
+        // VSFilterMod 扩展标签
+        // =====================================================
+
+        // --- \fsvp<offset> 垂直位置偏移 ---
+        } else if (tag("fsvp")) {
+            double val;
+            if (nargs) {
+                val = argtod(*args);
+                val = state->fsvp * (1 - pwr) + val * pwr;
+            } else {
+                val = 0;
+            }
+            state->fsvp = val;
+
+        // --- \frs<angle> 绕 Z 轴旋转（\frz 的别名）---
+        } else if (tag("frs")) {
+            double val;
+            if (nargs) {
+                val = argtod(*args);
+                val = state->frz * (1 - pwr) + val * pwr;
+            } else {
+                val = state->style->Angle;
+            }
+            state->frz = val;
+
+        // --- \z<depth> Z 轴深度 ---
+        } else if (tag("z")) {
+            double val;
+            if (nargs) {
+                val = argtod(*args);
+                val = state->z_depth * (1 - pwr) + val * pwr;
+            } else {
+                val = 0;
+            }
+            state->z_depth = val;
+
+        // --- \rndx<val> 随机 X 方向抖动 ---
+        } else if (tag("rndx")) {
+            double val;
+            if (nargs) {
+                val = argtod(*args);
+                val = state->rndx * (1 - pwr) + val * pwr;
+            } else {
+                val = 0;
+            }
+            state->rndx = val;
+
+        // --- \rndy<val> 随机 Y 方向抖动 ---
+        } else if (tag("rndy")) {
+            double val;
+            if (nargs) {
+                val = argtod(*args);
+                val = state->rndy * (1 - pwr) + val * pwr;
+            } else {
+                val = 0;
+            }
+            state->rndy = val;
+
+        // --- \rndz<val> 随机 Z 方向抖动 ---
+        } else if (tag("rndz")) {
+            double val;
+            if (nargs) {
+                val = argtod(*args);
+                val = state->rndz * (1 - pwr) + val * pwr;
+            } else {
+                val = 0;
+            }
+            state->rndz = val;
+
+        // --- \rnd<val> 随机全方向抖动 ---
+        } else if (tag("rnd")) {
+            double val;
+            if (nargs) {
+                val = argtod(*args);
+                val = state->rnd * (1 - pwr) + val * pwr;
+            } else {
+                val = 0;
+            }
+            state->rnd = val;
+
+        // --- \distort(u1,v1,u2,v2,u3,v3) 透视变形 ---
+        } else if (complex_tag("distort")) {
+            if (nargs >= 6) {
+                for (int i = 0; i < 3; i++) {
+                    double u = argtod(args[i * 2]);
+                    double v = argtod(args[i * 2 + 1]);
+                    state->distort_u[i] = state->distort_u[i] * (1 - pwr) + u * pwr;
+                    state->distort_v[i] = state->distort_v[i] * (1 - pwr) + v * pwr;
+                }
+                state->has_distort = 1;
+            } else if (!nargs) {
+                state->has_distort = 0;
+                for (int i = 0; i < 3; i++) {
+                    state->distort_u[i] = 0;
+                    state->distort_v[i] = 0;
+                }
+            }
+
+        // --- \$vc(<c1>,<c2>,<c3>,<c4>) 渐变颜色填充 ---
+        } else if (complex_tag("$vc")) {
+            if (nargs >= 4) {
+                for (int i = 0; i < 4; i++) {
+                    char *s = args[i].start;
+                    char *e = args[i].end;
+                    uint32_t color = 0;
+                    if (s < e && *s == '&') s++;
+                    if (s < e && (*s == 'H' || *s == 'h')) s++;
+                    while (s < e && *s != '&') {
+                        char c = *s++;
+                        uint32_t digit;
+                        if (c >= '0' && c <= '9') digit = c - '0';
+                        else if (c >= 'a' && c <= 'f') digit = c - 'a' + 10;
+                        else if (c >= 'A' && c <= 'F') digit = c - 'A' + 10;
+                        else break;
+                        color = (color << 4) | digit;
+                    }
+                    state->gradient_colors[i] = color;
+                }
+                state->has_gradient_color = 1;
+            } else if (!nargs) {
+                state->has_gradient_color = 0;
+                for (int i = 0; i < 4; i++)
+                    state->gradient_colors[i] = 0;
+            }
+
+        // --- \$va(<a1>,<a2>,<a3>,<a4>) 渐变透明度填充 ---
+        } else if (complex_tag("$va")) {
+            if (nargs >= 4) {
+                for (int i = 0; i < 4; i++) {
+                    char *s = args[i].start;
+                    char *e = args[i].end;
+                    uint32_t alpha = 0;
+                    if (s < e && *s == '&') s++;
+                    if (s < e && (*s == 'H' || *s == 'h')) s++;
+                    while (s < e && *s != '&') {
+                        char c = *s++;
+                        uint32_t digit;
+                        if (c >= '0' && c <= '9') digit = c - '0';
+                        else if (c >= 'a' && c <= 'f') digit = c - 'a' + 10;
+                        else if (c >= 'A' && c <= 'F') digit = c - 'A' + 10;
+                        else break;
+                        alpha = (alpha << 4) | digit;
+                    }
+                    state->gradient_alpha[i] = alpha & 0xFF;
+                }
+                state->has_gradient_alpha = 1;
+            } else if (!nargs) {
+                state->has_gradient_alpha = 0;
+                for (int i = 0; i < 4; i++)
+                    state->gradient_alpha[i] = 0;
+            }
+
+        // --- \1img(path) ~ \4img(path) VSFilterMod 纹理图片 ---
+        } else if (complex_tag("1img")) {
+            if (nargs) {
+                int len = args[0].end - args[0].start;
+                if (len > 0 && len < 1024) {
+                    free(state->channel_image_path[0]);
+                    state->channel_image_path[0] = strndup(args[0].start, len);
+                }
+            } else {
+                free(state->channel_image_path[0]);
+                state->channel_image_path[0] = NULL;
+            }
+        } else if (complex_tag("2img")) {
+            if (nargs) {
+                int len = args[0].end - args[0].start;
+                if (len > 0 && len < 1024) {
+                    free(state->channel_image_path[1]);
+                    state->channel_image_path[1] = strndup(args[0].start, len);
+                }
+            } else {
+                free(state->channel_image_path[1]);
+                state->channel_image_path[1] = NULL;
+            }
+        } else if (complex_tag("3img")) {
+            if (nargs) {
+                int len = args[0].end - args[0].start;
+                if (len > 0 && len < 1024) {
+                    free(state->channel_image_path[2]);
+                    state->channel_image_path[2] = strndup(args[0].start, len);
+                }
+            } else {
+                free(state->channel_image_path[2]);
+                state->channel_image_path[2] = NULL;
+            }
+        } else if (complex_tag("4img")) {
+            if (nargs) {
+                int len = args[0].end - args[0].start;
+                if (len > 0 && len < 1024) {
+                    free(state->channel_image_path[3]);
+                    state->channel_image_path[3] = strndup(args[0].start, len);
+                }
+            } else {
+                free(state->channel_image_path[3]);
+                state->channel_image_path[3] = NULL;
+            }
         }
     }
 
